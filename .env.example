# Porta HTTP da API principal
PORT=3333
NODE_ENV=development

# Conexão com o PostgreSQL da API principal
DATABASE_URL="postgresql://postoradar_api:postoradar_api@localhost:5432/postoradar_api?schema=public"

# Endereço do serviço de autenticação (usado para validar os tokens)
AUTH_SERVICE_URL="http://localhost:4000/api"

# Backend de mensageria: 'log' (registra eventos no console) ou 'kafka'
MESSAGING_DRIVER=log
